{
  "name": "next-shadcn-dashboard-starter",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Kiran",
    "url": "https://github.com/Kiranism"
  },
  "scripts": {
    "dev": "node scripts/postinstall.js 2>/dev/null; next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && bun format",
    "lint:strict": "oxlint --deny-warnings",
    "format": "oxfmt --write . '!**/*.md' '!**/*.mdc' '!**/*.mdx' '!**/*.yml' '!**/*.yaml'",
    "format:check": "oxfmt --check . '!**/*.md' '!**/*.mdc' '!**/*.mdx' '!**/*.yml' '!**/*.yaml'",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^7.3.5",
    "@sentry/nextjs": "^10.45.0",
    "@tabler/icons-react": "^3.40.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "kbar": "^0.1.0-beta.48",
    "match-sorter": "^8.2.0",
    "motion": "^11.18.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nuqs": "^2.8.9",
    "postcss": "8.5.14",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-dropzone": "^14.4.1",
    "react-resizable-panels": "^2.1.9",
    "react-responsive": "^10.0.1",
    "recharts": "^2.15.4",
    "sharp": "^0.33.5",
    "sonner": "^1.7.4",
    "sort-by": "^1.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.7.2",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/node": "22.10.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sort-by": "^1.2.3",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.14"
  },
  "lint-staged": {
    "!(scripts)/**/*.{js,jsx,tsx,ts,css,less,scss,sass}": [
      "oxfmt --write"
    ]
  }
}
